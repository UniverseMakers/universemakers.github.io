export default "# Stat display configuration for each simulation family.\n#\n# `summaryStats`\n#   End-of-run summary cards.\n#   - ids can refer to built-in app metrics such as `runtime`\n#   - ids can also refer to keys under the selected run's `run_summary.yaml`\n#     `summaryMetrics` map\n#   - `display_format` can be `integer`, `float`, or `scientific`\n#   - `precision` controls decimal places or scientific significant figures\n#\n# `liveStats`\n#   Top-right live telemetry rows.\n#   - `value` is the initial/fallback display value\n#   - `unit` is appended by the app\n#   - `live: true` means a CSV stream should provide updates\n#   - `live_key` can override which CSV column should be used\n#   - `from_video: true` means the final value should be pulled from the active\n#     video's sidecar metadata YAML\n#   - `video_key` can override which metadata key should be used\n#   - `scale_with_time: true` (when `live`) scales the final metadata value\n#     linearly by normalized playback time\n#   - `value_scale` multiplies a live numeric value before formatting\n\nplanetary:\n  summaryStats:\n    - id: runtime\n      value: '0.00'\n      unit: hours\n      from_video: true\n      video_key: wallclockSeconds\n    - id: similarityScore\n      value: 100/100\n    - id: carbonBurnt\n      value: '0.00'\n      unit: kgCO2e\n      from_video: true\n    - id: computeUsed\n      value: '0.0'\n      unit: smartphones\n      from_video: true\n    - id: memoryUsed\n      value: '0.0'\n      unit: GB\n      from_video: true\n    - id: particlesUpdated\n      value: '0'\n      label: Particle updates\n      from_video: true\n  liveStats:\n    - id: impactor_mass\n      value: '0.10'\n      unit: M⊕\n      live: false\n    - id: impactor_velocity\n      value: '12.0'\n      unit: km/s\n      live: false\n    - id: impactor_angle\n      value: '45'\n      unit: °\n      live: false\n    - id: time\n      value: 0.0\n      unit: hours\n      live: true\n    - id: temperature\n      value: 0.0\n      unit: K\n      live: true\n    - id: Earth mass\n      value: 1.0\n      unit: M⊕\n      live: true\n    - id: particlesUpdated\n      value: '0'\n      label: Particle updates\n      live: true\n      from_video: true\n      scale_with_time: true\n      integer: true\n\ngalaxy:\n  summaryStats:\n    - id: runtime\n      value: '0.00'\n      unit: hours\n      from_video: true\n      video_key: wallclockSeconds\n    - id: similarityScore\n      value: 100/100\n    - id: carbonBurnt\n      value: '0.00'\n      unit: kgCO2e\n      from_video: true\n    - id: computeUsed\n      value: '0.0'\n      unit: smartphones\n      from_video: true\n    - id: memoryUsed\n      value: '0.0'\n      unit: GB\n      from_video: true\n    - id: particlesUpdated\n      value: '0'\n      label: Particle updates\n      from_video: true\n  liveStats:\n    - id: star_formation_rate\n      value: '3.0'\n      unit: M☉/yr\n      live: true\n    - id: black_hole_mass\n      value: '4.0'\n      unit: ×10⁶ M☉\n      live: true\n    - id: stellar_mass\n      value: '5.0'\n      unit: ×10¹⁰ M☉\n      live: true\n    - id: size\n      value: 0.0\n      unit: kpc\n      live: true\n    - id: age\n      value: 0.0\n      unit: Gyr\n      live: true\n    - id: particlesUpdated\n      value: '0'\n      label: Particle updates\n      live: true\n      from_video: true\n      scale_with_time: true\n      integer: true\n\ncosmos:\n  summaryStats:\n    - id: runtime\n      value: '0.00'\n      unit: hours\n      from_video: true\n      video_key: wallclockSeconds\n    - id: similarityScore\n      value: 100/100\n    - id: carbonBurnt\n      value: '0.00'\n      unit: kgCO2e\n      from_video: true\n      display_format: float\n      precision: 2\n    - id: computeUsed\n      value: '0.0'\n      unit: smartphones\n      from_video: true\n      display_format: float\n      precision: 1\n    - id: memoryUsed\n      value: '0.0'\n      unit: GB\n      from_video: true\n      display_format: float\n      precision: 1\n    - id: particlesUpdated\n      value: '0'\n      label: Particle updates\n      from_video: true\n      display_format: integer\n  liveStats:\n    - id: age\n      value: 0.0\n      unit: Gyr\n      live: true\n      live_key: age_years\n      value_scale: 1.0e-9\n    - id: redshift\n      value: 0.0\n      unit: ''\n      live: true\n    - id: stellar_mass\n      value: '0'\n      label: Stellar Mass\n      unit: Msun\n      live: true\n    - id: bh_mass\n      value: '0'\n      label: Black Hole Mass\n      unit: Msun\n      live: true\n    - id: sfr\n      value: '0'\n      label: SFR\n      unit: Msun/yr\n      live: true\n    - id: g_updates_total\n      value: '0'\n      label: Particle updates\n      live: true\n      integer: true\n"