export default "# Parameter definitions for each simulation family.\n#\n# Each top-level key is a simulation family. Parameters are keyed by id\n# and define the range, step, defaults, and display formatting used by the\n# parameter editor sliders in the selection overlay.\n#\n# `description` fields appear in a popover when the user clicks the info\n# button next to a parameter name.\n\nplanetary:\n  impactor_mass:\n    label: Impactor Mass\n    description: Mass of the body colliding with the proto-Earth. Determines the mass of the debris disk and the resulting moon mass.\n    unit: M⊕\n    min: 0.01\n    max: 10\n    step: 0.01\n    default: 0.1\n  impactor_velocity:\n    label: Impactor Velocity\n    description: Relative velocity at which the impactor strikes the proto-Earth. Higher velocities produce more energetic collisions and hotter debris disks.\n    unit: km/s\n    min: 1\n    max: 50\n    step: 0.5\n    default: 12\n  impactor_angle:\n    label: Impactor Angle\n    description: Impact angle relative to the proto-Earth surface. Oblique impacts can produce different disk geometries than head-on collisions.\n    unit: °\n    min: 0\n    max: 90\n    step: 1\n    default: 45\n\ngalaxy:\n  star_formation_rate:\n    label: Star Formation Rate\n    description: Rate at which gas is converted into stars. Higher values produce more stellar mass, enriching the galaxy with metals from supernovae.\n    unit: M☉/yr\n    min: 0.1\n    max: 100\n    step: 0.1\n    default: 3\n  black_hole_mass:\n    label: Black Hole Mass\n    description: Initial mass of the supermassive black hole at the galactic centre. Drives active galactic nucleus feedback that can quench star formation.\n    unit: '×10⁶ M☉'\n    min: 0.1\n    max: 1000\n    step: 0.1\n    default: 4\n  stellar_mass:\n    label: Stellar Mass\n    description: Total stellar mass of the galaxy. Controls luminosity, metal production, and the gravitational potential well of the system.\n    unit: '×10¹⁰ M☉'\n    min: 0.01\n    max: 50\n    step: 0.01\n    default: 5\n\ncosmos:\n  baryon_fraction:\n    label: Baryon Fraction\n    description: The fraction of matter that is ordinary (visible/baryonic) versus dark matter. This controls the amount of gas available in the Universe for star and galaxy formation. One of the main goals in cosmological simulations is testing fundamental cosmological parameters such as this fraction.\n    unit: ''\n    min: 0.10\n    max: 4\n    step: 0.01\n    default: 1\n    value_scale: 0.1536\n  black_hole_strength:\n    label: Black Hole Strength\n    description: The temperature of gas that can escape from a black hole. As gas falls in towards a black hole, it becomes superheated and forms an \"accretion disc\" around the black hole. This superheated plasma wants to escape and does so either as heat dumped into the environment or \"jets\" blasted out from the poles. Astrophysicists call this \"feedback\" but exactly how strong this feedback is, and the manner in which it leaves the black hole is up for debate.\n    unit: 'K'\n    min: 0.01\n    max: 6.67\n    step: 0.01\n    default: 1\n    value_scale: 1.0e8\n    display_format: scientific\n    display_significant_figures: 3\n  gravity_strength:\n    label: Gravity\n    description: The strength of gravity, as described by Newton's gravitational constant G. Varying G changes the rate at which matter collapses into cosmic structures like dark matter halos and the cosmic web.\n    unit: 'm^3 kg^-1 s^-2'\n    min: 0.01\n    max: 10\n    step: 0.01\n    default: 1\n    value_scale: 6.6743e-11\n    display_format: scientific\n    display_significant_figures: 3\n"